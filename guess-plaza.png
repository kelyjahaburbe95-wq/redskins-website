    <script>
    const cookieWallParamName = "thirdPartyCookies";
    const cookieWallParamValue = "disabled";
    const algoliaEnabledCache = "algoliaEnabledCache";
    const algoliaEnabledCacheParamValue = "enabled";

    function registerServiceWorker(){
        let swUrl = '/sw.js?v=0&locale=fr_FR&'+cookieWallParamName+'='+cookieWallParamValue+'&'+algoliaEnabledCache+'='+algoliaEnabledCacheParamValue;
        navigator.serviceWorker.register(swUrl).then(function(reg){
            console.log("SW registration succeeded. Scope is " + reg.scope);
            
        }).catch(function(err){
            console.error("SW registration failed with error " + err);
        });
    }

    function hasParamValueChanged(url, paramName, expectedValue) {
        try {
            const urlObj = new URL(url);
            const params = new URLSearchParams(urlObj.search);
            const paramValue = params.get(paramName);

            return paramValue !== expectedValue;
        } catch (error) {
            console.error('Invalid URL:', error);
            return false;
        }
    }
    
    if('serviceWorker' in navigator) {
        // Register service worker
        window.addEventListener('load', () => {
            let fanplayrSWPath = "/fr-fr/serviceWorker";
            navigator.serviceWorker.getRegistrations().then(function(registrations) {
                registrations.forEach((registration) => {
                    if(registration && registration.active){
                        let scriptURL = registration.active.scriptURL;
                        if(scriptURL.indexOf(fanplayrSWPath)>=0){
                            registration.unregister();
                        } else if(hasParamValueChanged(scriptURL, cookieWallParamName, cookieWallParamValue)){
                            registration.unregister();
                        } else if(hasParamValueChanged(scriptURL, algoliaEnabledCache, algoliaEnabledCacheParamValue)){
                            registration.unregister();                            
                        }
                    }
                });
            }).finally(()=> {
                registerServiceWorker();
            });
        });
        
    }
    </script>



