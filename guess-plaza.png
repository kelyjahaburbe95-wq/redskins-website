/*CLIENT CUSTOM CSS*/.cmpboxwelcomeprps{display:flex; border-top:1px solid #D6D6D6;
border-bottom:1px solid #D6D6D6; align-content:stretch; justify-content:space-between; }
.cmpwelcomeprps{ display:flex; padding:1.5em 1em; flex-direction: column-reverse;  margin:0px; border-right:1px solid #D6D6D6; position:relative; gap:10px; flex-grow: 1;}
.cmpwelcomeprps .cmptogglespan svg{width:70px; height:40px;}
.cmpbox .cmpboxbtncustom, .cmpbox .cmpboxbtnyescustomchoices  {color:var(--clrButton)!important; border-color:var(--clrButton)!important; background-color:var(--clrButtonText) !important;}
.cmpwelcomeprps {width:auto !important;}

.cmplogo2, 
.cmplogoXL { 
  display: none; 
} .cmpstyleroot, .cmpstyleroot *
{
    --clrBackground:    #FFFFFF;
    --clrHeadline:      #3B3B3B;
    --clrText:          #5F5F5F;
    --clrTextSecondary: #CFCFCF;
    --clrButton:        #3276AE;
    --clrButtonText:    #FFFFFF;
    --clrLink:          #666666;
    --clrHighlight:     #FFFDCD;
}.cmplogo {left: 20px; top: 13px;}
