            padding: 0 36px;
        }

        #Brands--megamenu .brands--list {
            margin-bottom: 0 !important;
            width: 100% !important;
            box-sizing: border-box;
        }

        #Brands--megamenu .brands--mobile--cta img {
            max-height: 16px;
            width: auto !important;
            display: block;
            position: relative;
            margin-left: 50%;
            transform: translateX(-50%);
        }

        #Brands--megamenu .brands--mobile--cta {
            width: 100% !important;
            background: #3e3e3e !important;
            border: 2px solid #3e3e3e !important;
            padding: 24px 0 !important;
        }

        #Brands--megamenu .brands--mobile--margin {
            margin: 12px auto !important;
        }

        #Brands--megamenu .brands--mobile--margin:first-child {
            margin-bottom: 12px !important;
            margin-top: 24px !important;
        }

        #Brands--megamenu .brands--mobile--margin:last-child {
            margin-bottom: 12px !important;
        }

        #Brands--megamenu .bg--gray .flex__section {
            margin-bottom: 0 !important;
        }

        #Brands--megamenu .max-300 {
            max-width: 300px !important;
        }

        [data-store="Guess"] #Brands--megamenu .brands--list.section--mobile .brand--guess:after {
            content: "";
            position: absolute;
            left: 0;
            height: 100%;
            top: 0;
