<link id="alternate-style" rel="alternate" href="https://www.guess.eu/fr-fr/guess/homme/chaussures-et-accessoires/chaussures/baskets-a-logo-plaza-blanc/FMJAVILEA12-WHITE.html">
<script>
var abcountry = document.querySelector("html").getAttribute("data-country")
function getCookie(nome) {
    var nomeEQ = nome + "=";
    var cookies = document.cookie.split(';');
    for (var i = 0; i < cookies.length; i++) {
        var c = cookies[i].trim();
        if (c.indexOf(nomeEQ) === 0) {
            return c.substring(nomeEQ.length, c.length);
        }
    }
    return null;
}

if (getCookie('ABimagesJeans')) {
     document.getElementById('alternate-style').href = 'https://content.guess.com/guesseurope/css/ABtestimagesJeans.css';
     document.getElementById('alternate-style').rel = 'stylesheet';
}
</script>
