<script>
	var theCountry = document.querySelector("html").getAttribute("data-country") || "GB"
	    var theLanguage = document.querySelector("html").getAttribute("data-lang") || "en"
	
	    function FAQcall(theLanguage, theCountry) {
	
	        var rootcall = 'https://www.guess.eu'
	
	        if (window.location.href.indexOf('staging-eu01-guess') > -1) {
	            rootcall = 'https://staging-eu01-guess.demandware.net/s/guess_fr'
	        }
	
	        if (window.location.href.indexOf('staging.guess.eu') > -1) {
	            rootcall = 'https://staging.guess.eu/'
	        }
	
	        var APIURL = rootcall + '/dw/shop/v20_10/content/eu-needhelp-content?locale=' + theLanguage + '-' + theCountry + '&client_id=c83b61a8-b468-4e63-94fc-e9647617f9dc'
	
	        fetch(APIURL).then(function(response) {
	            return response.json();
	        }).then(function(data) {
	
	
	
	            var shippingInfo = document.createElement("div")
	            shippingInfo.innerHTML = data.c_body
	
	            var selector = "#inj_shippingTime .show-in-" + theCountry.toUpperCase()
	            shippingInfo = shippingInfo.querySelector(selector)
	
	            document.querySelector(".deliveryAndReturnsContainer .injectedShippingTime").append(shippingInfo)
	
	
	            var guaranteedDelivery = document.createElement("div")
	            guaranteedDelivery.innerHTML = data.c_body
	
	
	            if (guaranteedDelivery.querySelector(".consegnagarantita.show-in-" + theCountry.toUpperCase())) {
	
