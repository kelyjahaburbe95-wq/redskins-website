	            feeReturnMsg = "* Let wel dat in geval van een retour van producten voor orders boven 100€ bezorgd met Levering aan huis, een bedrag van 3,95€ voor verzendkosten zal worden verrekend. Deze verzendkosten worden afgetrokken van het retourbedrag. Retours in Guess winkels zijn altijd gratis. ";
	        } else if (theLanguage === "el") {
	            feeReturnMsg = "* Please note that in case of return of products for orders above 100€ shipped with Home Delivery, a shipping cost of 3,95€ will be applied. The shipping costs will be deducted from the refund amount. Returns in Guess stores are always free of charge.";
	        } else if (theLanguage === "tr") {
