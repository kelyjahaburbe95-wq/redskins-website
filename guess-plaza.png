<script>
    document.addEventListener('DOMContentLoaded', (event) => {
        function getCookieValue(name) {
            return document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)')?.pop() || null;
        }

        const cookieValue = getCookieValue('Guess.CookieWallThirdParties');
        const cookieWallSet = getCookieValue('Guess.CookieWallSet');
        const consent = cookieValue === 'true' ? 'granted' : 'denied'

        window.uetq = window.uetq || [];
        window.uetq.push('consent', 'default', {
            'ad_storage': 'denied'
        });

        if(cookieWallSet === 'true') {
            window.uetq.push('consent', 'update', {
                'ad_storage': consent
            });
        }
    });
</script>



    
    










