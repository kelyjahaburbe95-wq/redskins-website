	        } else {
	            feeReturnMsg = "* Please note that in case of return of products for orders above 100€ shipped with Home Delivery, a shipping cost of 3,95€ will be applied. The shipping costs will be deducted from the refund amount. Returns in Guess stores are always free of charge. ";
	        }
	    }
	
	    if (
	        theCountry === "SG"
	    ) {
	        var feeReturnSG = document.createElement("span");
	        feeReturnSG.innerHTML = "We apply a return fee of 15SGD for returns with carrier pick up. Returns in store are free. The fee will be deducted from the refund amount.";
	        feeReturnSG.classList.add("return--fee--span");
	        document.querySelector(".deliveryAndReturnsContainer .deliveryContent:nth-child(2) .row").appendChild(feeReturnSG);
	    }
	
	    if (
	        theCountry === "AT" || theCountry === "FR" || theCountry === "DE" || theCountry === "IT" ||
	        theCountry === "NL" || theCountry === "BE" || theCountry === "BG" || theCountry === "HR" ||
	        theCountry === "CY" || theCountry === "CZ" || theCountry === "DK" || theCountry === "FI" ||
