	    function addText() {
	
	        var translatedStrings = eval("shared." + theLanguage) || shared.en
	
	        Object.keys(translatedStrings).forEach(function(key) {
	            var selector = "[data-translation='" + key + "']"
	            if (document.querySelector(selector)) {
	                if (selector == "[data-translation='free_on_over']") {
	                    var element = document.querySelectorAll(selector)
	                    element = [].slice.call(element)
	                    element.forEach(function(el) {
	                        var country
	
	                        var classNames = el.parentElement.parentElement.className.split(" ")
	
	                        for (var x = 0; x < classNames.length; x++) {
	                            if (classNames[x].indexOf("show-in-") === 0) {
	                                country = classNames[x].split('-')[2]
	                                break
	                            }
	
	                        }
	
	                        if (country != undefined) {
	                            el.innerHTML = translatedStrings[key] + " " + shippingFreeOver[country]
	                        }
	
	                    })
	                } else if (selector == "[data-translation='outlet_fee']") {
	                    var element = document.querySelectorAll(selector)
	                    element = [].slice.call(element)
	                    element.forEach(function(el) {
	                        var country
	
	                        var classNames = el.parentElement.className.split(" ")
	
	                        for (var x = 0; x < classNames.length; x++) {
	                            if (classNames[x].indexOf("show-in-") === 0) {
	                                country = classNames[x].split('-')[2]
	                                break
	                            } else {
	                                country = theCountry
	                            }
	                        }
	
	
	                        if (shippingFee[country] == undefined) {
	                            el.innerHTML = translatedStrings[key].replace("[PRICE]", "4€")
	                        } else {
	                            el.innerHTML = translatedStrings[key].replace("[PRICE]", shippingFee[country])
	                        }
	
	                    })
	                } else {
	                    var element = document.querySelectorAll(selector)
	                    element = [].slice.call(element)
	                    element.forEach(function(el) {
	                        el.innerHTML = translatedStrings[key]
	                    })
	                }
	
	            }
	        });
	    }
	
	
