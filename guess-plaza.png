            document.querySelector(".header-container .header-banner .shippingLink").classList.add("no__shrinked")
        }

    }, 50)



    function waitForEl(selector, myFunction, intervalTime) {
        var interval = setInterval(function() {
            if (document.querySelector(selector)) {
                myFunction();
                clearInterval(interval);
            }
            var firefoxTimeout = setTimeout(function() {
                var firstItemLogo = document.querySelector(".header__logo-container .small-logo")
                var rightLogo
                firstItemLogo.classList.forEach(function(el) {
                    if (el.indexOf("mobile-header-brand-logo") > -1) {
                        rightLogo = el.replace("mobile-header-brand-logo-", "")
                    }
                })

                if (!document.querySelector(".header__brand--link.active")) {
                    document.querySelector(".header__brands--container [data-brand-id='" + rightLogo + "'] a").classList.add("active")
                }

            }, 2000)


        }, intervalTime);
    }

