	    }
	
	    .deliveryContent.flexAlign {
	        display: flex;
	        flex-direction: column;
	        width: 49%;
	        justify-content: space-between;
	    }
	
	    .deliveryContent.flexAlign:nth-child(1) {
	        margin-right: 5%;
	        border-right: 1px solid #e0e0e0;
	    }
	
	    .deliveryAndReturnsContainer .col-sm-3.col-lg-3.col-md-3.col-xs-12.tabletitle {
	        font-weight: 600;
	        -webkit-box-flex: 0;
	        -ms-flex: 0 0 35%;
	        flex: 0 0 35%;
	        max-width: 35%;
	    }
	
	    .deliveryAndReturnsContainer .col-sm-9.col-lg-9.col-md-9.col-xs-12 {
	        -webkit-box-flex: 0;
	        -ms-flex: 0 0 65%;
	        flex: 0 0 65%;
	        max-width: 65%;
