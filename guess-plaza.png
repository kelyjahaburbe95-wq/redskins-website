        }

        #Brands--megamenu .brands--list--item a {
            height: 100%;
            width: 100vw;
            display: block;
        }

        #Brands--megamenu .text--gray {
            color: #1d1d1d !important;
            opacity: 0.7;
        }

        #Brands--megamenu .bg--gray {
            background: #f3f3f3;
        }

        #Brands--megamenu .bg--gray .flex__section {
